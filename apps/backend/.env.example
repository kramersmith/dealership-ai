# Database
DATABASE_URL=sqlite:///./dealership.db

# Auth
SECRET_KEY=dev-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS
CORS_ORIGINS=["http://localhost:8081","http://localhost:19006"]

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Vehicle Intelligence
VINAUDIT_API_KEY=your-vinaudit-api-key

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MAX_TOKENS=1024
# CLAUDE_MAX_HISTORY=20
# Context compaction (see docs/adr/0017-context-compaction-custom.md)
# CLAUDE_COMPACTION_ENABLED=true
# CLAUDE_CONTEXT_INPUT_BUDGET=180000
# CLAUDE_COMPACTION_WARN_BUFFER_TOKENS=20000
# CLAUDE_COMPACTION_AUTO_BUFFER_TOKENS=13000
# CLAUDE_COMPACTION_VERBATIM_MESSAGES=8
# LOG_LEVEL=INFO
# NHTSA_VPIC_BASE_URL=https://vpic.nhtsa.dot.gov/api/vehicles
# VINAUDIT_HISTORY_URL=https://marketvalue.vinaudit.com/getvehiclehistoryreport.php
# VINAUDIT_VALUATION_URL=https://marketvalue.vinaudit.com/getmarketvalue.php
